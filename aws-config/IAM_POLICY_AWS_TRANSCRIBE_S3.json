{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AmazonTranscribeFullAccess",
            "Effect": "Allow",
            "Action": [
                "transcribe:StartStreamTranscription",
                "transcribe:StartMedicalStreamTranscription",
                "transcribe:StartCallAnalyticsJob",
                "transcribe:CreateVocabulary",
                "transcribe:*"
            ],
            "Resource": "*"
        },
        {
            "Sid": "S3AccessForTranscribe",
            "Effect": "Allow",
            "Action": [
                "s3:CreateBucket",
                "s3:PutObject",
                "s3:GetObject",
                "s3:DeleteObject",
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::aireceptionist-transcribe-*",
                "arn:aws:s3:::aireceptionist-transcribe-*/*"
            ]
        },
        {
            "Sid": "S3ListBuckets",
            "Effect": "Allow",
            "Action": [
                "s3:ListAllMyBuckets"
            ],
            "Resource": "*"
        }
    ]
}